# Test Environment Configuration
# This file contains environment-specific settings for testing

# Application Configuration
SKIP_MIGRATIONS=true
TESTING=true
ENVIRONMENT=test

# Test Database Configuration
TEST_DATABASE_URL=sqlite:///./test_medical_records.db
TEST_DATABASE_RESET=true

# Test User Configuration
TEST_ADMIN_USERNAME=testadmin
TEST_ADMIN_EMAIL=testadmin@example.com
TEST_ADMIN_PASSWORD=testadminpass123

TEST_USER_USERNAME=testuser
TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=testuserpass123

# Test API Configuration
TEST_API_TIMEOUT=30
TEST_MAX_RETRIES=3

# Test File Upload Configuration
TEST_UPLOAD_DIR=./test_uploads
TEST_MAX_FILE_SIZE=10485760  # 10MB

# Security Testing
TEST_JWT_SECRET=test_jwt_secret_key_for_testing_only
TEST_PASSWORD_MIN_LENGTH=8

# Performance Testing
TEST_CONCURRENT_USERS=10
TEST_REQUEST_TIMEOUT=5

# Coverage Settings
COVERAGE_THRESHOLD=80
COVERAGE_EXCLUDE_LINES=pragma: no cover,def __repr__,raise AssertionError,raise NotImplementedError

# Logging Configuration for Tests
TEST_LOG_LEVEL=INFO
TEST_LOG_FILE=./test_logs.log

# Feature Flags for Testing
ENABLE_SLOW_TESTS=false
ENABLE_INTEGRATION_TESTS=true
ENABLE_SECURITY_TESTS=true
ENABLE_PERFORMANCE_TESTS=false
